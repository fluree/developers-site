{
  "id": "reference/http-api/queries/explain",
  "description": "Get the query execution plan for a FlureeQL query",
  "testable": true,
  "endpoint": "POST /v1/fluree/explain",
  "body": "explain.json",
  "setup": [
    "shared/create-test-ledger",
    "shared/cookbook-base-seed"
  ],
  "expected": {
    "status": 200,
    "bodyContains": {
      "plan": {
        "optimization": "none",
        "reason": "No statistics available",
        "where-clause": {
          "@id": "?s",
          "schema:name": "?name"
        }
      }
    }
  }
}
